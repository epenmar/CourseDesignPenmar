SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
ALLOWED_ORIGINS=http://localhost:3000
ENCRYPTION_KEY=generate-with-python-secrets-token-hex-32
CREATE_AI_API_KEY=your-asu-aiml-api-key
CREATE_AI_API_URL=https://api-main.aiml.asu.edu/query
CREATE_AI_API_MODEL=claude4_5_sonnet
CREATE_AI_API_PROVIDER=aws
# Optional: use a smaller/cheaper text model for link text suggestions while keeping image generation on the main model.
CREATE_AI_LINK_TEXT_MODEL=
CREATE_AI_LINK_TEXT_PROVIDER=
# Optional: use a larger-output text model for Canvas Create / Course Creation outline generation.
CREATE_AI_CANVAS_CREATE_MODEL=
CREATE_AI_CANVAS_CREATE_PROVIDER=
CREATE_AI_CANVAS_CREATE_MAX_TOKENS=4096
CREATE_AI_CANVAS_CREATE_COMPACT_MAX_TOKENS=3000
TAGFLOW_PREVIEW_MAX_PAGES_PER_JOB=12
TAGFLOW_AUTO_PREVIEW_MAX_PAGES_PER_JOB=0
IMAGE_THUMB_PREWARM_LIMIT=24
