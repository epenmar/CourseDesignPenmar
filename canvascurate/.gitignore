# Reference repo (old codebase — read only, never import)
_reference/

# Python
__pycache__/
*.py[cod]

# OS
.DS_Store

# Env files — keys live in /Users/epenmar/conductor/.env (central source
# of truth). backend/.env is typically a symlink to that file; never
# commit either it or the frontend's .env.local even when both contain
# only public values, so future drift to actual secrets can't sneak in.
.env
.env.local
.env.*.local
backend/.env
frontend/.env.local
